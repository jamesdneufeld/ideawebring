{
  "version": 1,
  "repo": {
    "owner": "jamesdneufeld",
    "name": "ideawebring",
    "branch": "main"
  },
  "excludeFolders": [".git", ".vscode", "admin", "js", "css", "lib", "assets", "blank-bdes", "blank-ixd", "ixd", "james", "james-in-class", "learning", "log"],
  "defaults": {
    "program": "BDes",
    "year": "2026",
    "resumeRequirementMet": false
  },
  "options": {
    "programs": ["BDes", "IxD"],
    "years": ["2024", "2025", "2026", "2027", "2028", "2029", "2030", "2031", "2032"]
  },
  "matchRules": [
    { "name": "exact", "weight": 100 },
    { "name": "normalized", "weight": 80 },
    { "name": "github", "weight": 60 }
  ],
  "ui": {
    "title": "🕸️ Web Ring · Merge Engine",
    "subhead": "Ranked rule-based identity reconciliation — stores static metadata only"
  }
}
